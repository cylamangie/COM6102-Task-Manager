# App
NODE_ENV=development
PORT=5173

# PostgreSQL
# If using your own/global Postgres, set the values to match your instance.
# docker-compose.local-db.yml uses these same defaults.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=taskdb

# Optional app secret
JWT_SECRET=change-me-in-production
